PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/employee-leave-portal
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# File storage — local by default (saved in backend/uploads/)
# Optional Cloudinary: https://cloudinary.com
# Dashboard → Home (cloud name) → Settings → API Keys → Root API key + secret
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
